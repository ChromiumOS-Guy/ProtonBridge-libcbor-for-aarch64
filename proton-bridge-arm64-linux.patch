@@ -22,8 +22,21 @@ cmake_minimum_required(VERSION 3.22)
 #*****************************************************************************************************************************************************
 
 set(CMAKE_INSTALL_RPATH "${CMAKE_INSTALL_BINDIR}" "${CMAKE_INSTALL_LIBDIR}" "." "../lib")
-install(DIRECTORY "${QT_DIR}/qml" "${QT_DIR}/plugins"
-        DESTINATION "${CMAKE_INSTALL_PREFIX}")
+
+# Prefer qmake-reported paths (Fedora/etc), fall back to old layout
+set(_qml_dir "${QT_QML_DIR}")
+set(_plugins_dir "${QT_PLUGINS_DIR}")
+
+if(NOT EXISTS "${_qml_dir}")
+  set(_qml_dir "${QT_DIR}/qml")
+endif()
+if(NOT EXISTS "${_plugins_dir}")
+  set(_plugins_dir "${QT_DIR}/plugins")
+endif()
+
+install(DIRECTORY "${_qml_dir}" "${_plugins_dir}"
+        DESTINATION "${CMAKE_INSTALL_PREFIX}"
+        USE_SOURCE_PERMISSIONS)
 
